# ─────────────────────────────────────────────────────────────────────────────
# JobClaw — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already gitignored.
# Full variable inventory: context/architecture.md → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Neo4j (Required — powers entire website + agent data) ────────────────────
# Get from: https://console.neo4j.io  (create a free Aura instance)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-aura-password

# ── Session Cookie ────────────────────────────────────────────────────────────
# At least 32 random characters. Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-32-plus-random-characters-here

# ── Web3Auth (Social Login — Primary Onboarding) ─────────────────────────────
# Get client ID from: https://dashboard.web3auth.io
# Network: sapphire_devnet for dev/staging | sapphire_mainnet for production
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your-web3auth-client-id-from-dashboard
NEXT_PUBLIC_WEB3AUTH_NETWORK=sapphire_devnet

# ── Chain ─────────────────────────────────────────────────────────────────────
# 84532 = Base Sepolia (dev/staging) | 8453 = Base mainnet (final demo video)
NEXT_PUBLIC_CHAIN_ID=84532

# ── Vercel Blob (Resume PDFs, cover letters, screenshots) ────────────────────
# Get from Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Venice AI (Primary LLM — required for prize track) ───────────────────────
# Get from: https://venice.ai  Default model: venice/kimi-k2-5
VENICE_API_KEY=your-venice-api-key

# ── Browserbase (Browser Automation — LinkedIn, Greenhouse, direct URLs) ─────
# Get from: https://www.browserbase.com
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# ── Exa (Job Discovery) ───────────────────────────────────────────────────────
# Get from: https://exa.ai
EXA_API_KEY=your-exa-api-key

# ── Brave Search (URL enrichment + company context) ──────────────────────────
# Get from: https://brave.com/search/api
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# ── OpenClaw (Separate Repo — Venice reasoning control plane) ─────────────────
# Deploy jobclaw-openclaw first, then fill these in
OPENCLAW_BASE_URL=https://your-openclaw-project.vercel.app
OPENCLAW_ADMIN_SECRET=replace-with-32-plus-random-characters-here
OPENCLAW_BYPASS_SECRET=replace-with-32-plus-random-characters-here

# ── Agentic RAG API Secret ────────────────────────────────────────────────────
# Shared secret between jobclaw and jobclaw-openclaw — must match in both repos
RAG_API_SECRET=replace-with-32-plus-random-characters-here

# ── 1Shot Permissionless Relayer (EIP-7702 + EIP-7710) ───────────────────────
# Get from 1Shot hackathon docs / dashboard
ONESHOT_API_KEY=your-1shot-api-key
ONESHOT_API_SECRET=your-1shot-api-secret

# ── x402 Payment Gating ───────────────────────────────────────────────────────
# USDC on Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# USDC on Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
X402_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Your wallet address to receive x402 payments
X402_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Deployment (OpenClaw uses this to call /api/rag/* back into jobclaw) ──────
JOBCLAW_BASE_URL=https://jobclaw.vercel.app
